# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE — PostgreSQL (Supabase recommended)
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Create project at https://supabase.com
# 2. Project Settings → Database → Connection string (URI)
#    - Use "Transaction" pooler for DATABASE_URL (port 6543)
#    - Use direct connection for DIRECT_DATABASE_URL (port 5432)
#
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ═══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION — NextAuth.js v5
# ═══════════════════════════════════════════════════════════════════════════════
# Generate secret: openssl rand -base64 32 (min 32 chars required)
# AUTH_SECRET is the primary key name (NEXTAUTH_SECRET also supported for backwards compatibility)
#
AUTH_SECRET="your-secret-here-min-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# Google OAuth Setup
# ===========================================
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URIs:
#    - http://localhost:3000/api/auth/callback/google (dev)
#    - https://your-domain.com/api/auth/callback/google (prod)
# 4. Copy Client ID and Client Secret below
#
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# OAuth (opcional - no implementado actualmente)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ===========================================
# Email Service (Resend recommended)
# ===========================================
# Option 1: Resend (recommended)
# 1. Create account at https://resend.com
# 2. Get API key from https://resend.com/api-keys
# 3. Verify your domain at https://resend.com/domains
# 4. Set RESEND_FROM to a verified sender (e.g., "noreply@yourdomain.com")
#
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM="Trading Bot <noreply@yourdomain.com>"

# Option 2: SMTP (fallback)
# Configure these if you prefer SMTP over Resend
#
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_FROM="Trading Bot <noreply@example.com>"

# ===========================================
# Stripe Payments
# ===========================================
# 1. Create account at https://stripe.com
# 2. Get API keys from https://dashboard.stripe.com/test/apikeys
# 3. Create products/prices at https://dashboard.stripe.com/products
# 4. Set up webhook at https://dashboard.stripe.com/webhooks
#    Endpoint: https://your-domain.com/api/stripe/webhook
#    Events: checkout.session.completed, customer.subscription.updated,
#            customer.subscription.deleted, invoice.payment_failed
#
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PRICE_BASIC="price_xxx"
STRIPE_PRICE_PRO="price_xxx"
STRIPE_PRICE_ENTERPRISE="price_xxx"

# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION URL
# ═══════════════════════════════════════════════════════════════════════════════
# Used for generating absolute URLs in emails, webhooks, and redirects
# Development: http://localhost:3000
# Production: https://your-domain.com
#
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ═══════════════════════════════════════════════════════════════════════════════
# TELEGRAM BOT (Optional - for signal ingestion)
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Create bot via @BotFather on Telegram → /newbot
# 2. Copy the bot token
# 3. Set webhook: POST to https://api.telegram.org/bot<TOKEN>/setWebhook
#    with {"url": "https://your-domain.com/api/telegram/webhook"}
#
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrsTUVwxyz"

# ═══════════════════════════════════════════════════════════════════════════════
# CREDENTIALS ENCRYPTION (Required for storing MT5 credentials)
# ═══════════════════════════════════════════════════════════════════════════════
# Generate a 64-character hex key: openssl rand -hex 32
# Used to encrypt MT5 API keys stored in database
# WARNING: Changing this key will invalidate all existing encrypted credentials
#
CREDENTIALS_ENCRYPTION_KEY="your-64-character-hex-key-here-use-openssl-rand-hex-32"

# ═══════════════════════════════════════════════════════════════════════════════
# AI AGENT (Optional - for trading assistant features)
# ═══════════════════════════════════════════════════════════════════════════════
# At least one provider is required if using AI features
# Get OpenAI key: https://platform.openai.com/api-keys
# Get Anthropic key: https://console.anthropic.com/settings/keys
#
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxx"
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx"

# ═══════════════════════════════════════════════════════════════════════════════
# VERCEL (Auto-set by platform - do not configure manually)
# ═══════════════════════════════════════════════════════════════════════════════
# VERCEL_URL - Auto-set on Vercel deployments
# VERCEL - Set to "1" when running on Vercel
#
# Optional for deployments via CI/CD:
# VERCEL_TOKEN - Get from https://vercel.com/account/tokens
